local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- === Permanent Key ===
local validKey = "notpaki12"

-- === Create GUI ===
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "pakikey"
screenGui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 350, 0, 180)
frame.Position = UDim2.new(0.5, -175, 0.5, -90)
frame.BackgroundColor3 = Color3.fromRGB(50, 40, 0)
frame.BorderSizePixel = 0
frame.AnchorPoint = Vector2.new(0.5, 0.5)
frame.Parent = screenGui
frame.ClipsDescendants = true
frame.Active = true
frame.Draggable = true -- Make draggable

-- Shiny gold stroke
local stroke = Instance.new("UIStroke")
stroke.Parent = frame
stroke.Color = Color3.fromRGB(255, 215, 0)
stroke.Thickness = 4

-- Notification function
local function Notify(title, text, duration)
	game.StarterGui:SetCore("SendNotification", {
		Title = title;
		Text = text;
		Duration = duration;
	})
end

-- Example notification
Notify("Script", "Join discord to get key : .gg/Yu3WByND!", 5)

-- Tween for pulsating glow
local tweenInfo = TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
local glowTween = TweenService:Create(stroke, tweenInfo, {Transparency = 0.5})
glowTween:Play()

-- TextBox
local textBox = Instance.new("TextBox")
textBox.PlaceholderText = "Enter the key..."
textBox.Size = UDim2.new(0, 300, 0, 45)
textBox.Position = UDim2.new(0.5, -150, 0, 25)
textBox.BackgroundColor3 = Color3.fromRGB(255, 250, 200)
textBox.TextColor3 = Color3.fromRGB(0, 0, 0)
textBox.TextScaled = true
textBox.ClearTextOnFocus = false
textBox.Parent = frame

-- Submit Button
local submitButton = Instance.new("TextButton")
submitButton.Text = "Unlock"
submitButton.Size = UDim2.new(0, 120, 0, 45)
submitButton.Position = UDim2.new(0.5, -60, 0, 85)
submitButton.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
submitButton.TextColor3 = Color3.fromRGB(0,0,0)
submitButton.TextScaled = true
submitButton.Parent = frame

-- Feedback Label
local feedbackLabel = Instance.new("TextLabel")
feedbackLabel.Size = UDim2.new(1, -20, 0, 30)
feedbackLabel.Position = UDim2.new(0, 10, 0, 140)
feedbackLabel.BackgroundTransparency = 1
feedbackLabel.TextScaled = true
feedbackLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
feedbackLabel.Text = ""
feedbackLabel.Parent = frame

-- === Verify key function ===
local function verifyKey(key)
    if key == validKey then
        return true, "Correct key! Running script..."
    else
        return false, "Invalid key!"
    end
end

-- === Button click ===
submitButton.MouseButton1Click:Connect(function()
    local key = textBox.Text
    local success, message = verifyKey(key)
    feedbackLabel.Text = message

    if success then
        -- Success glow animation
        local successTween = TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {BackgroundColor3 = Color3.fromRGB(255, 230, 150)})
        successTween:Play()

        -- Run the external script safely
        local success, err = pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/melanie198686-tech/rizz/refs/heads/main/rizz%20script"))()
        end)
        if not success then
            warn("Failed to run script: ", err)
        end

        -- Close GUI after 1 second
        wait(1)
        frame:TweenPosition(UDim2.new(0.5, -175, -1, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.5, true)
        wait(0.5)
        screenGui:Destroy()
    end
end)
