-- Aura Tab
local AuraTab = Window:CreateTab("Aura", 4483362458)

-- Function to create floating Aura number above your head
local function addAura(amount)
    local player = game.Players.LocalPlayer
    local char = player.Character
    if not char then return end

    local head = char:FindFirstChild("Head")
    if not head then return end

    -- Create BillboardGui
    local auraGui = Instance.new("BillboardGui")
    auraGui.Name = "AuraDisplay"
    auraGui.Adornee = head
    auraGui.Size = UDim2.new(0, 100, 0, 50)
    auraGui.StudsOffset = Vector3.new(0, 3, 0)
    auraGui.AlwaysOnTop = true

    -- Label
    local label = Instance.new("TextLabel")
    label.Parent = auraGui
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextScaled = true
    label.TextColor3 = Color3.fromRGB(0, 255, 255)
    label.TextStrokeTransparency = 0
    label.Text = "+ " .. amount .. " Aura"
    label.Font = Enum.Font.Fantasy

    auraGui.Parent = head

    -- Optional: Make it fade and disappear after 3 seconds
    game:GetService("TweenService"):Create(label, TweenInfo.new(3), {TextTransparency = 1}):Play()
    game:GetService("Debris"):AddItem(auraGui, 3)
end

-- Button +100 Aura
AuraTab:CreateButton({
    Name = "+100 Aura",
    Callback = function()
        addAura(100)
    end
})

-- Button +1000 Aura
AuraTab:CreateButton({
    Name = "+1000 Aura",
    Callback = function()
        addAura(1000)
    end
})
