-- Modern draggable toggle button
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "ModernToggleButton"
screenGui.Parent = playerGui

local button = Instance.new("Frame")
button.Name = "ToggleButton"
button.Size = UDim2.new(0, 120, 0, 50)
button.Position = UDim2.new(0.5, -60, 0.5, -25)
button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
button.BorderSizePixel = 0
button.AnchorPoint = Vector2.new(0.5, 0.5)
button.Parent = screenGui
button.Active = true
button.Draggable = true

local uicornerBtn = Instance.new("UICorner")
uicornerBtn.CornerRadius = UDim.new(0, 15)
uicornerBtn.Parent = button

local label = Instance.new("TextLabel")
label.Size = UDim2.new(1, 0, 1, 0)
label.BackgroundTransparency = 1
label.Text = "OFF"
label.TextColor3 = Color3.fromRGB(255, 255, 255)
label.Font = Enum.Font.GothamBold
label.TextScaled = true
label.Parent = button

local isOn = false

local function toggle()
    isOn = not isOn
    LethalDash = isOn
    if isOn then
        button.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        label.Text = "ON"
    else
        button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        label.Text = "OFF"
    end
end

button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        toggle()
    end
end)

-- Lethal Dash key detection
UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if not LethalDash then return end
    if Cooldown then return end

    if input.KeyCode == Enum.KeyCode.One then
        local char = Player.Character
        if not char then return end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        Cooldown = true
        task.wait(TeleportDelay)
        hrp.CFrame = hrp.CFrame + hrp.CFrame.LookVector * DashDistance

        task.delay(DelayBeforeThree, function()
            VIM:SendKeyEvent(true, Enum.KeyCode.Three, false, game)
            VIM:SendKeyEvent(false, Enum.KeyCode.Three, false, game)
        end)

        task.wait(AbilityCooldown)
        Cooldown = false
    end
end)
